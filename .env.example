# JARVIS Configuration
# Copy to .env and fill in your values

# OpenRouter API Key (REQUIRED for cloud AI)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenRouter Base URL (optional, default below)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default Model (optional, default: openrouter/free)
JARVIS_MODEL=openrouter/free

# Governance Level: 0=Low, 1=Medium, 2=High
JARVIS_GOVERNANCE_LEVEL=1

# Python executable path (optional)
JARVIS_PYTHON_PATH=python
