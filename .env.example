# JARVIS Configuration
# The app has a built-in API key — it works out of the box.
# Copy this file to .env ONLY if you want to use your own key.

# OpenRouter API Key (get yours free at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenRouter Base URL (optional)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default Model
JARVIS_MODEL=google/gemini-2.0-flash-exp:free

# Governance Level: 0=Low, 1=Medium, 2=High
JARVIS_GOVERNANCE_LEVEL=1

# Python executable path (optional)
JARVIS_PYTHON_PATH=python
